{
  "schema_version": "1.0",
  "role": "mtm",
  "schemas": {
    "tool_delivery": {
      "description": "MTM delivers a tool to an SPM or CR agent (TDL)",
      "message_type": "tool_delivery",
      "type_code": "TDL",
      "fields": {
        "schema_version": "1.0",
        "message_type": "tool_delivery",
        "timestamp": "ISO 8601",
        "from_role": "mtm",
        "to_role": "spm_{subsystem} or cr_{subsystem}",
        "message_id": "TDL-MTM-{SEQUENCE}",
        "status": "unread",
        "in_response_to": "TRQ message_id that triggered this delivery",
        "tool_id": "string — unique tool identifier from registry",
        "tool_name": "string",
        "tool_description": "What it does and how to use it",
        "tool_location": ".agents/tools/{tool_filename}",
        "tool_type": "test_harness | code_generator | build_script | static_analysis | benchmark | mock | debug_aid | other",
        "tool_version": 1,
        "usage_instructions": "Step by step: how to invoke, required inputs, expected outputs",
        "known_limitations": "Edge cases, known gaps, or empty string"
      }
    },
    "tool_update": {
      "description": "MTM notifies SPMs that a shared tool has changed (TUP)",
      "message_type": "tool_update",
      "type_code": "TUP",
      "fields": {
        "schema_version": "1.0",
        "message_type": "tool_update",
        "timestamp": "ISO 8601",
        "from_role": "mtm",
        "to_role": "spm_{subsystem}",
        "message_id": "TUP-MTM-{SEQUENCE}",
        "status": "unread",
        "tool_id": "string",
        "tool_name": "string",
        "previous_version": 1,
        "new_version": 2,
        "tool_location": ".agents/tools/{tool_filename}",
        "change_summary": "What changed and why",
        "breaking_changes": true,
        "migration_notes": "What the SPM needs to tell its TMs to update, or empty string"
      }
    },
    "shared_tool_notice": {
      "description": "MTM informs other SPMs that a new shared tool is available (STN)",
      "message_type": "shared_tool_notice",
      "type_code": "STN",
      "fields": {
        "schema_version": "1.0",
        "message_type": "shared_tool_notice",
        "timestamp": "ISO 8601",
        "from_role": "mtm",
        "to_role": "spm_{subsystem}",
        "message_id": "STN-MTM-{SEQUENCE}",
        "status": "unread",
        "tool_id": "string",
        "tool_name": "string",
        "tool_description": "Brief description of what it does",
        "tool_location": ".agents/tools/{tool_filename}",
        "tool_type": "string",
        "original_requester": "spm_{subsystem} who originally requested it",
        "request_to_use": "Send TRQ to MTM referencing this tool_id to receive a TDL"
      }
    },
    "deprecation_notice": {
      "description": "MTM notifies SPMs that a tool is being deprecated (DPN)",
      "message_type": "deprecation_notice",
      "type_code": "DPN",
      "fields": {
        "schema_version": "1.0",
        "message_type": "deprecation_notice",
        "timestamp": "ISO 8601",
        "from_role": "mtm",
        "to_role": "spm_{subsystem}",
        "message_id": "DPN-MTM-{SEQUENCE}",
        "status": "unread",
        "tool_id": "string",
        "tool_name": "string",
        "reason": "Why it is being deprecated",
        "replacement_tool_id": "string — replacement tool_id, or empty string if none",
        "grace_period_sessions": 1,
        "removal_session": "Session number after which tool will be removed"
      }
    },
    "status_report": {
      "description": "MTM reports status to PPM (SRP)",
      "message_type": "status_report",
      "type_code": "SRP",
      "fields": {
        "schema_version": "1.0",
        "message_type": "status_report",
        "timestamp": "ISO 8601",
        "from_role": "mtm",
        "to_role": "ppm",
        "message_id": "SRP-MTM-{SEQUENCE}",
        "in_response_to": "SRQ message_id if responding to request, empty string if proactive",
        "status": "unread",
        "open_requests": {
          "received": 0,
          "assessing": 0,
          "building": 0
        },
        "delivered_this_session": 0,
        "updated_this_session": 0,
        "total_tools_in_registry": 0,
        "stalled_requests": [
          {
            "trq_message_id": "string",
            "requesting_spm": "string",
            "sessions_open": 0,
            "reason": "string"
          }
        ],
        "mtm_health": "green | amber | red",
        "health_rationale": "One line"
      }
    },
    "escalation": {
      "description": "MTM escalates a problem to PPM (ESC)",
      "message_type": "escalation",
      "type_code": "ESC",
      "fields": {
        "schema_version": "1.0",
        "message_type": "escalation",
        "timestamp": "ISO 8601",
        "from_role": "mtm",
        "to_role": "ppm",
        "message_id": "ESC-MTM-{SEQUENCE}",
        "status": "unread",
        "trq_message_id": "TRQ that triggered this escalation, or empty string",
        "escalation_reason": "production_code_request | registry_conflict | architectural_input_needed | uncovered_situation",
        "situation": "Full description",
        "recommended_resolution": "MTM proposed path forward"
      }
    }
  }
}
